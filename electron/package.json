{
  "name": "gadir-iptv-player",
  "version": "1.0.0",
  "description": "Gadir IPTV Player - IPTV Player Windows Desktop",
  "main": "main.js",
  "author": "Gadir IPTV",
  "scripts": {
    "start": "electron .",
    "prebuild": "node ./scripts/prepare.js",
    "build": "electron-builder --win --x64 --publish never",
    "dist": "yarn --cwd ../frontend build && node ./scripts/prepare.js && electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "electron-builder": "24.13.3",
    "resedit": "^3.0.2"
  },
  "build": {
    "appId": "com.gadir.tv",
    "productName": "Gadir IPTV Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png",
      "app/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gadir IPTV Player"
    }
  }
}
