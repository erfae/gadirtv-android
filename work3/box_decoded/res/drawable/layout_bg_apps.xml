<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:state_enabled="true">
        <shape>
            <solid android:color="@color/apps_selected_background" />
            <stroke android:width="@dimen/dimen_3dp" android:color="@color/White1" />
            <corners android:radius="@dimen/dimen_8dp" />
        </shape>
    </item>
    <item android:state_enabled="true" android:state_selected="false">
        <shape>
            <solid android:color="@color/apps_selected_background" />
            <corners android:radius="@dimen/dimen_8dp" />
            <padding android:left="@dimen/dp_5" android:top="@dimen/epg_box_10dp" android:right="@dimen/dp_5" android:bottom="@dimen/epg_box_10dp" />
        </shape>
    </item>
</selector>