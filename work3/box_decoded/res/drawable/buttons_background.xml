<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/mago_catchup_buttons" />
    <item android:drawable="@drawable/activated_mago_catchup_buttons" android:state_activated="true" />
    <item android:state_pressed="true" android:drawable="@drawable/mago_catchup_buttons" />
    <item>
        <shape>
            <solid android:color="#ff44484b" />
            <stroke android:width="0.0dip" android:color="@color/mago_light_blue" />
