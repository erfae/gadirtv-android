<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vodControlsRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/vod_scrim_bottom"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/vodTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/vodPosition"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/gtv_text_dim"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/vodSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:focusable="true"
            android:max="1000"
            android:nextFocusDown="@+id/btnVodPlayPause"
            android:progressTint="@color/gtv_red"
            android:thumbTint="@color/gtv_red_hi" />

        <TextView
            android:id="@+id/vodDuration"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0:00"
            android:textColor="@color/gtv_text_dim"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnVodRewind"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/player_rewind"
            android:focusable="true"
            android:nextFocusRight="@+id/btnVodPlayPause"
            android:nextFocusUp="@+id/vodSeekBar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_rewind" />

        <ImageButton
            android:id="@+id/btnVodPlayPause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/player_play_pause"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVodRewind"
            android:nextFocusRight="@+id/btnVodForward"
            android:nextFocusUp="@+id/vodSeekBar"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pause" />

        <ImageButton
            android:id="@+id/btnVodForward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/player_forward"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVodPlayPause"
            android:nextFocusRight="@+id/btnVodVolDown"
            android:nextFocusUp="@+id/vodSeekBar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_forward" />

        <ImageButton
            android:id="@+id/btnVodVolDown"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/volume_down"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVodForward"
            android:nextFocusRight="@+id/btnVodVolUp"
            android:nextFocusUp="@+id/vodSeekBar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_volume_down" />

        <ImageButton
            android:id="@+id/btnVodVolUp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/volume_up"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVodVolDown"
            android:nextFocusUp="@+id/vodSeekBar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_volume_up" />
    </LinearLayout>
</LinearLayout>
