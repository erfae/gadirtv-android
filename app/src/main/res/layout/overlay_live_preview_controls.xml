<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/miniPreviewOverlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/vod_scrim_bottom"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingTop="10dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/gtv_red"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="@string/epg_now"
            android:textColor="@android:color/white"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/epgNow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/epg_unavailable"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/epgNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/gtv_text_dim"
        android:textSize="10sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnVolDown"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/volume_down"
            android:focusable="true"
            android:nextFocusRight="@+id/btnVolUp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_volume_down" />

        <ImageButton
            android:id="@+id/btnVolUp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/volume_up"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVolDown"
            android:nextFocusRight="@+id/btnFullscreen"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_volume_up" />

        <ImageButton
            android:id="@+id/btnFullscreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/player_control_bg"
            android:contentDescription="@string/fullscreen"
            android:focusable="true"
            android:nextFocusLeft="@+id/btnVolUp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_fullscreen" />
    </LinearLayout>
</LinearLayout>
