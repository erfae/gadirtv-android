<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlcVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        android:id="@+id/vlcVolumeControls"
        layout="@layout/player_volume_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp" />

    <ImageButton
        android:id="@+id/btnVlcBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="72dp"
        android:background="@drawable/player_control_bg"
        android:contentDescription="@string/back"
        android:focusable="true"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_back"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/vlcOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/player_overlay_scrim"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/vlcTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/vlcEpgNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="#F2FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/vlcEpgNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/gtv_text_dim"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
