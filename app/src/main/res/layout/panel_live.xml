<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryList"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.28"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusRight="@+id/channelList"
        android:padding="8dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gtv_border" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelList"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.36"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@+id/categoryList"
        android:padding="8dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gtv_border" />

    <LinearLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.36"
        android:background="@android:color/black"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.media3.ui.PlayerView
                android:id="@+id/miniPlayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:keepScreenOn="true"
                app:show_buffering="never"
                app:use_controller="false" />

            <include
                android:id="@+id/miniNoSignal"
                layout="@layout/overlay_no_signal" />

            <include
                android:id="@+id/miniVolumeControls"
                layout="@layout/player_volume_controls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp" />

            <TextView
                android:id="@+id/previewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#99000000"
                android:ellipsize="end"
                android:maxLines="1"
                android:padding="10dp"
                android:text="@string/select_channel"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gtv_border" />

        <LinearLayout
            android:id="@+id/epgBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gtv_surface"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/gtv_red"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="@string/epg_now"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/epgNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/epg_unavailable"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/epgNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/gtv_text_dim"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
