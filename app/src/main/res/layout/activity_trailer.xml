<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/trailerPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:visibility="gone"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:use_controller="false" />

    <WebView
        android:id="@+id/trailerWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <TextView
        android:id="@+id/trailerStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:text="@string/trailer_loading"
        android:textColor="@color/gtv_text_dim"
        android:textSize="15sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/trailerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnTrailerBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/tab_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@+id/btnTrailerRetry"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/back"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnTrailerRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/btn_trailer_hero"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@+id/btnTrailerBack"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="@string/trailer_retry"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/trailerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/trailerEndOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingVertical="22dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/trailer_finished"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnTrailerReplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_trailer_hero"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusRight="@+id/btnTrailerExit"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:text="@string/trailer_replay"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnTrailerExit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:background="@drawable/tab_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/btnTrailerReplay"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:text="@string/trailer_exit"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
