<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gtv_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitStart"
            android:src="@drawable/gadir_logo" />

        <TextView
            android:id="@+id/headerExpiration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:maxLines="2"
            android:textColor="@color/gtv_text_dim"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/gtv_text_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_bg"
            android:contentDescription="@string/search_title"
            android:drawableStart="@drawable/ic_search"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:minWidth="36dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="" />

        <TextView
            android:id="@+id/btnReload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_bg"
            android:contentDescription="@string/reload_playlist"
            android:drawableStart="@drawable/ic_reload"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:minWidth="36dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="" />

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_bg"
            android:contentDescription="@string/settings_title"
            android:drawableStart="@drawable/ic_settings"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:minWidth="36dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="@drawable/tab_bg"
            android:contentDescription="@string/logout_user"
            android:drawableStart="@drawable/ic_logout"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:minWidth="36dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="" />

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp">

            <View
                android:id="@+id/profileAvatarCircle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/avatar_bg" />

            <TextView
                android:id="@+id/profileAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/btnExit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/tab_bg"
            android:contentDescription="@string/exit_app"
            android:drawableStart="@drawable/ic_power"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:minWidth="36dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gtv_border" />

    <FrameLayout
        android:id="@+id/contentPanels"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            android:id="@+id/panelHome"
            layout="@layout/panel_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ViewStub
            android:id="@+id/panelLiveStub"
            android:inflatedId="@+id/panelLive"
            android:layout="@layout/panel_live"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/panelMovies"
            layout="@layout/panel_catalog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gtv_border" />

    <include layout="@layout/bottom_nav" />
</LinearLayout>
