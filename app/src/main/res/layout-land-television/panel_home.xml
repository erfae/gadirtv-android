<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/heroContainer"
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:background="@color/gtv_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants">

        <ImageView
            android:id="@+id/heroImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/hero_placeholder_bg" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/hero_scrim_left" />

        <LinearLayout
            android:id="@+id/heroTextColumn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="32dp"
            android:paddingVertical="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_synopsis_label"
                    android:textColor="@color/gtv_red_hi"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/heroPlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/heroPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/btn_hero_play_solid"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:minWidth="200dp"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="14dp"
                    android:text="@string/hero_play"
                    android:textAllCaps="true"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/heroPoster"
                android:layout_width="90dp"
                android:layout_height="128dp"
                android:layout_marginStart="16dp"
                android:background="@color/gtv_surface"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/hero_placeholder_bg" />
        </LinearLayout>
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:fillViewport="true"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/homeLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/loading"
                android:textColor="@color/gtv_text_dim"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/homeEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/home_empty"
                android:textColor="@color/gtv_text_dim"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/resumeRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_continue"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/resumeRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none"
                android:visibility="gone" />

            <TextView
                android:id="@+id/favoritesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_favorites"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favoritesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none"
                android:visibility="gone" />

            <TextView
                android:id="@+id/moviesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="6dp"
                android:text="@string/rail_recent_movies"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/moviesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="108dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/seriesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="2dp"
                android:text="@string/rail_recent_series"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/seriesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="108dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:scrollbars="none" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
