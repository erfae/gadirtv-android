<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0612"
    android:orientation="horizontal">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryList"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.34"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusRight="@+id/channelList"
        android:padding="8dp"
        android:scrollbars="vertical" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelList"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.30"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@+id/categoryList"
        android:nextFocusRight="@+id/previewContainer"
        android:padding="8dp"
        android:scrollbars="vertical" />

    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.36"
        android:background="#FF14101F"
        android:clickable="true"
        android:descendantFocusability="afterDescendants"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@+id/channelList">

        <include layout="@layout/include_live_preview_panel" />
    </FrameLayout>
</LinearLayout>
