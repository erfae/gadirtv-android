<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/heroContainer"
        android:layout_width="match_parent"
        android:layout_height="205dp"
        android:background="@color/gtv_bg"
        android:descendantFocusability="afterDescendants">

        <ImageView
            android:id="@+id/heroImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/tv_banner" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/hero_scrim_left" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="32dp"
            android:paddingVertical="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_synopsis_label"
                    android:textColor="@color/gtv_red_hi"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/heroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/heroPlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/heroPlay"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/btn_play_hero"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:gravity="center"
                        android:minWidth="148dp"
                        android:nextFocusRight="@+id/heroTrailer"
                        android:paddingHorizontal="20dp"
                        android:text="@string/hero_play"
                        android:textAllCaps="true"
                        android:textColor="@color/hero_play_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/heroTrailer"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/btn_trailer_hero"
                        android:drawableStart="@drawable/ic_trailer"
                        android:drawablePadding="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:gravity="center_vertical"
                        android:minWidth="148dp"
                        android:nextFocusLeft="@+id/heroPlay"
                        android:paddingHorizontal="18dp"
                        android:text="@string/hero_trailer"
                        android:textAllCaps="true"
                        android:textColor="@color/hero_trailer_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/heroPoster"
                android:layout_width="120dp"
                android:layout_height="170dp"
                android:layout_marginStart="20dp"
                android:background="@color/gtv_surface"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/tv_banner" />
        </LinearLayout>
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:fillViewport="true"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/homeLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/loading"
                android:textColor="@color/gtv_text_dim"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/homeEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/home_empty"
                android:textColor="@color/gtv_text_dim"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/resumeRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_continue"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/resumeRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none"
                android:visibility="gone" />

            <TextView
                android:id="@+id/favoritesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_favorites"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favoritesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none"
                android:visibility="gone" />

            <TextView
                android:id="@+id/moviesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_recent_movies"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/moviesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="140dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/seriesRailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="12dp"
                android:text="@string/rail_recent_series"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/seriesRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="140dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:scrollbars="none" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
