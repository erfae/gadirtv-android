<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/catalogCategoryList"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusRight="@+id/catalogGrid"
        android:padding="6dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gtv_border" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/catalogGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:nextFocusLeft="@+id/catalogCategoryList"
            android:padding="6dp"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/catalogLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/loading"
            android:textColor="@color/gtv_text_dim"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/catalogEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/catalog_empty"
            android:textColor="@color/gtv_text_dim"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
