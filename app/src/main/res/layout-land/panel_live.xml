<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryList"
        android:layout_width="112dp"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusRight="@+id/channelList"
        android:padding="4dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gtv_border" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelList"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@+id/categoryList"
        android:padding="4dp"
        android:scrollbars="vertical" />

    <!-- Stubs ocultos: el código de preview sigue existiendo pero no se usa en móvil -->
    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">

        <View
            android:id="@+id/miniVlcPlayer"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/miniNoSignal"
            layout="@layout/overlay_no_signal" />

        <ImageView
            android:id="@+id/previewLogo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/previewTitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/epgNow"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/epgNext"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/miniPreviewControls"
            layout="@layout/overlay_live_preview_controls"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </FrameLayout>
</LinearLayout>
