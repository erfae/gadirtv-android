<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gtv_bg"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/movieBackdrop"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/tv_banner" />

        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/hero_scrim_left" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_synopsis_label"
                    android:textColor="@color/gtv_red_hi"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/movieType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/hero_type_movie"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/movieTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/movieMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/moviePlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="5"
                    android:textColor="#D9FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/movieDirector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/movieCast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/gtv_text_dim"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnMoviePlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_play_hero"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"
                    android:text="@string/hero_play"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/moviePoster"
                android:layout_width="90dp"
                android:layout_height="135dp"
                android:layout_marginStart="12dp"
                android:background="@color/gtv_surface"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/tv_banner" />
        </LinearLayout>

        <TextView
            android:id="@+id/movieLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:minHeight="240dp"
            android:text="@string/loading"
            android:textColor="@color/gtv_text_dim"
            android:textSize="14sp" />
    </FrameLayout>
</ScrollView>
