<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFD54F" />
            <stroke
                android:width="2dp"
                android:color="#FFFFD54F" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#22FFD54F" />
            <stroke
                android:width="1dp"
                android:color="#88FFD54F" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/gtv_surface" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
