<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Manifest override — cronet_http declares minSdk 24 but the app
         gracefully falls back to IOClient on older devices. -->
    <uses-sdk tools:overrideLibrary="io.flutter.plugins.cronet_http" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.faketouch"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.gamepad"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.location"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false"
        tools:node="merge"
        tools:replace="android:required" />

    <application
        android:label="GadirTV"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@drawable/tv_banner"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        android:hardwareAccelerated="true"
        tools:replace="android:extractNativeLibs">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="landscape">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <!-- Launchers: both leanback (Android TV) and standard so the
                 app is discoverable on any launcher shell — some Xiaomi and
                 generic TV boxes ship a hybrid launcher that expects both
                 intent filters and refuses to start apps that declare only
                 one. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <meta-data
            android:name="com.google.android.tv.feature"
            android:value="true" />

        <!-- Force legacy Skia renderer instead of Impeller. Some Android
             TV boxes (esp. Amlogic S905-based Xiaomi Mi TV Box variants)
             ship GPU drivers with broken Vulkan/GLES3 support, which
             makes Impeller silently crash at startup before Flutter can
             even render its splash screen. Skia is slower but works on
             every device Flutter has ever supported. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
        <!-- Disable the new Android SurfaceControl path introduced in
             Flutter 3.24+. Some Sony Bravia and Xiaomi Amlogic firmwares
             (Android 9-11) ship broken SurfaceControl implementations
             that make the Flutter engine crash before rendering. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableSurfaceControl"
            android:value="false" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>
</manifest>
