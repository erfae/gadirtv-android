<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP for the Xtream Codes provider (gadir.co runs on port 80).
  Everything else is left to the platform's secure defaults.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
